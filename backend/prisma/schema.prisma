generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid()) @map("_id")
  name          String?
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Better Auth Fields
  sessions    Session[]
  accounts    Account[]
  twoFactors  TwoFactor[]
  passkeys    Passkey[]
  members     Member[]
  invitations Invitation[]

  // Admin Plugin
  role       String    @default("CUSTOMER") // SUPER_ADMIN | ADMIN | STAFF | CUSTOMER
  banned     Boolean   @default(false)
  banReason  String?
  banExpires DateTime?

  // App Specific
  favoriteNumber Int? @default(0)

  // Legacy / Hybrid Compatibility Fields
  password           String?
  isVerified         Boolean   @default(false)
  hashedRefreshToken String?
  verificationToken  String?
  resetToken         String?
  resetTokenExpires  DateTime?
  avatar             String?

  // E-commerce Relations 
  orders  Order[]
  reviews Review[]
  cart    Cart?

  // Legacy Enum Role Support
  legacyRole Role @default(CUSTOMER)

  @@map("user")
}

model Session {
  id                   String   @id @default(cuid()) @map("_id")
  expiresAt            DateTime
  token                String   @unique
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  ipAddress            String?
  userAgent            String?
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrganizationId String?
  impersonatedBy       String?

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid()) @map("_id")
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid()) @map("_id")
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

model TwoFactor {
  id          String @id @default(cuid()) @map("_id")
  secret      String
  backupCodes String
  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("two_factor")
}

model Passkey {
  id           String    @id @default(cuid()) @map("_id")
  name         String?
  publicKey    String
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialID String
  counter      Int
  deviceType   String
  backedUp     Boolean
  transports   String?
  createdAt    DateTime?

  @@map("passkey")
}

model Organization {
  id          String       @id @default(cuid()) @map("_id")
  name        String
  slug        String?      @unique
  logo        String?
  createdAt   DateTime     @default(now())
  metadata    String?
  members     Member[]
  invitations Invitation[]

  @@map("organization")
}

model Member {
  id             String       @id @default(cuid()) @map("_id")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       @default("member")
  createdAt      DateTime     @default(now())

  @@map("member")
}

model Invitation {
  id             String       @id @default(cuid()) @map("_id")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String       @default("pending")
  expiresAt      DateTime
  inviterId      String
  inviter        User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@map("invitation")
}

// --------------------------------------------------------
// E-commerce Models
// --------------------------------------------------------

model Category {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  slug         String    @unique
  description  String?
  isActive     Boolean   @default(true)
  isComingSoon Boolean   @default(false)
  displayOrder Int       @default(0)
  imageUrl     String?
  products     Product[]

  @@map("category")
}

model Coupon {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  code           String       @unique
  discountType   DiscountType
  value          Int
  minOrderAmount Int?
  maxUses        Int?
  usedCount      Int          @default(0)
  expiresAt      DateTime?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())

  @@map("coupon")
}

model Region {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  code      String   @unique // US, NG, GH, etc.
  currency  String   @default("USD")
  symbol    String   @default("$")
  isActive  Boolean  @default(true)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ProductRegionalPrice ProductRegionalPrice[]
  Cart                 Cart[]
  Order                Order[]

  @@map("region")
}

model ExchangeRate {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  currency  String   @unique // NGN, GHS, etc.
  rate      String   // Rate against USD (Stored as string for precision)
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@map("exchange_rate")
}

model Product {
  id                   String      @id @default(auto()) @map("_id") @db.ObjectId
  name                 String
  description          String
  basePriceUSD_cents   Int         @map("basePriceUSD") // Mapping to existing field but using new naming convention
  salePriceUSD_cents   Int?        @map("salePriceUSD") // Mapping to existing field
  stock                Int
  isActive             Boolean     @default(true)
  images               String[]    // Keeping as fallback array
  productImages        ProductImage[]
  categoryId           String      @db.ObjectId
  slug                 String      @unique
  tags                 String[]
  attributes           Json?
  hasVariants          Boolean     @default(false)
  weightKG             Float       @default(0)
  
  // New Variant System
  variants             Variant[]
  
  // Legacy / Hybrid Fields (to be deprecated)
  options              Json?       
  legacyVariants       Json?       @map("variants")
  customizationOptions Json? 
  
  regionalPrices       ProductRegionalPrice[]
  
  createdAt            DateTime    @default(now())
  orderItems           OrderItem[]
  category             Category    @relation(fields: [categoryId], references: [id])
  reviews              Review[]
  cartItems            CartItem[]

  @@map("product")
}

model Color {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String    @unique
  hexCode   String
  variants  Variant[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("color")
}

model Pattern {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  name            String    @unique
  previewImageUrl String
  variants        Variant[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("pattern")
}

model ProductImage {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  productId  String   @db.ObjectId
  imageUrl   String
  sortOrder  Int      @default(0)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@map("product_image")
}

model Variant {
  id                 String         @id @default(auto()) @map("_id") @db.ObjectId
  productId          String         @db.ObjectId
  colorId            String?        @db.ObjectId
  patternId          String?        @db.ObjectId
  size               String?
  priceUSD_cents     Int?           // Overrides base price
  salePriceUSD_cents Int?           // Overrides base sale price
  sku                String?        // Unique SKU for the variant
  stock              Int            @default(0)
  imageUrl           String?        // PRIMARY DISPLAY IMAGE
  options            Json?          // Stores combinations like {"Color": "Red", "Size": "XL"}
  
  product            Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  color              Color?         @relation(fields: [colorId], references: [id])
  pattern            Pattern?       @relation(fields: [patternId], references: [id])
  images             VariantImage[]
  
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@map("variant")
}

model VariantImage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  variantId String   @db.ObjectId
  imageUrl  String
  sortOrder Int      @default(0)
  variant   Variant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("variant_image")
}

model ProductRegionalPrice {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  productId  String @db.ObjectId
  regionCode String // US, NG, etc.
  price      Int    // Price in regional currency (cents)
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  region     Region  @relation(fields: [regionCode], references: [code])

  @@unique([productId, regionCode])
  @@map("product_regional_price")
}

model Cart {
  id               String     @id @default(auto()) @map("_id") @db.ObjectId
  userId           String?    @unique
  regionCode       String
  currency         String
  exchangeRateUsed String     // Stored as string
  
  // Deterministic Charge Persistence
  chargeCurrency   String?
  chargeTotal      Int?       // (cents)
  displaySubtotal  Int?       // (cents)

  items            CartItem[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  user             User?      @relation(fields: [userId], references: [id])
  region           Region     @relation(fields: [regionCode], references: [code])

  @@map("cart")
}

model CartItem {
  id            String  @id @default(auto()) @map("_id") @db.ObjectId
  cartId        String  @db.ObjectId
  productId     String  @db.ObjectId
  quantity      Int
  customization Json?
  cart          Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product       Product @relation(fields: [productId], references: [id])

  @@map("cart_item")
}

model Order {
  id               String      @id @default(auto()) @map("_id") @db.ObjectId
  userId           String?
  status           OrderStatus
  
  // Shipping & Tracking
  carrier          String?
  trackingNumber   String?
  paidAt           DateTime?
  shippedAt        DateTime?
  deliveredAt      DateTime?

  // Architectural Dual-Currency Fields (Unambiguous)
  displayCurrency  String      @default("USD")
  displayTotal     Int         @default(0) // (cents)
  chargeCurrency   String      @default("USD")
  chargeTotal      Int         @default(0) // (cents)
  totalUSD         Int         @default(0) // (canonical base in cents)
  
  // Legacy / Basic Totals
  total            Int         @default(0) // (cents)
  currency         String      @default("USD")
  
  paymentId        String?
  createdAt        DateTime    @default(now())
  email            String
  shippingAddress  Json
  user             User?       @relation(fields: [userId], references: [id])
  items            OrderItem[]

  // Commerce Strategy Fields
  regionCode       String
  exchangeRateUsed String
  shippingCost     Int         @default(0) // (cents)
  isCustomOrder    Boolean     @default(false)
  customerPhone    String?
  
  region           Region      @relation(fields: [regionCode], references: [code])

  @@map("order")
}

model OrderItem {
  id               String  @id @default(auto()) @map("_id") @db.ObjectId
  orderId          String  @db.ObjectId
  productId        String  @db.ObjectId
  variantId        String?
  quantity         Int
  unitPriceUSD     Int     // (cents)
  exchangeRateUsed String
  unitPriceFinal   Int     // Final unit price (after regional override or FX)
  weightKG         Float?
  
  price            Int     // Legacy: Total line price (final * qty)
  customization    Json?   // Store customization snapshot
  order            Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product          Product @relation(fields: [productId], references: [id])

  @@map("order_item")
}

model ShippingZone {
  id          String           @id @default(auto()) @map("_id") @db.ObjectId
  name        String           // US-EAST, Nigeria-Default, etc.
  type        ShippingZoneType
  countryCode String           // US, NG, etc.
  states      String[]         // ["NY", "NJ"] or ["*"]
  flatRateUSD Int              // Base rate in USD
  
  @@unique([type, countryCode])
  @@map("shipping_zone")
}

enum ShippingZoneType {
  REGIONAL_FLAT
  COUNTRY_DEFAULT
  GLOBAL_DEFAULT
}

model Review {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  rating    Int
  comment   String
  productId String   @db.ObjectId
  userId    String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("review")
}

model StoreSettings {
  id           String   @id @default(cuid()) @map("_id")
  storeName    String   @default("My Store")
  description  String?
  currency     String   @default("NGN")
  supportEmail String?
  socialLinks  Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("store_settings")
}

model ShippingConfig {
  id                            String   @id @default(auto()) @map("_id") @db.ObjectId
  usFlatRateInCents             Int      @default(1500)
  nigeriaFlatRateInCents        Int      @default(2500)
  indiaFlatRateInCents          Int      @default(2500)
  ghanaFlatRateInCents          Int      @default(2500)
  chinaFlatRateInCents          Int      @default(2500)
  internationalFlatRateInCents  Int      @default(2500) // "Others" category
  updatedAt                     DateTime @updatedAt

  @@map("shipping_config")
}

model CmsPage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  slug      String   @unique
  title     String
  content   String
  metadata  Json?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cms_page")
}

model GalleryItem {
  id           String          @id @default(auto()) @map("_id") @db.ObjectId
  type         GalleryItemType
  url          String
  tag          String?
  displayOrder Int             @default(0)
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())

  @@map("gallery_item")
}

enum GalleryItemType {
  IMAGE
  VIDEO
}

enum SectionType {
  ANNOUNCEMENT
  HERO
  MARQUEE
  FEATURED
  PROMO
  NEW_ARRIVALS
  MOST_POPULAR
  FLASH_SALE
  CATEGORIES
}

model HomepageSection {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  type        SectionType
  referenceId String?
  order       Int         @default(0)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("homepage_section")
}

model Announcement {
  id              String    @id @default(cuid()) @map("_id")
  message         String
  ctaText         String?
  ctaLink         String?
  isActive        Boolean   @default(true)
  startAt         DateTime?
  endAt           DateTime?
  backgroundColor String    @default("#000000")
  textColor       String    @default("#ffffff")
  priority        Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("announcement")
}

model HeroSection {
  id         String   @id @default(cuid()) @map("_id")
  title      String   // Massive Headline
  imageUrl   String?
  videoUrl   String?
  mediaType  String   @default("IMAGE") // IMAGE | VIDEO
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("hero_section")
}

model MarqueeItem {
  id        String   @id @default(cuid()) @map("_id")
  icon      String?
  text      String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("marquee_item")
}

model FeaturedCollection {
  id          String   @id @default(cuid()) @map("_id")
  title       String
  description String?
  isActive    Boolean  @default(true)
  productIds  String[] @db.ObjectId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("featured_collection")
}

model PromoBanner {
  id             String   @id @default(cuid()) @map("_id")
  title          String
  subtitle       String?
  imageUrl       String
  ctaText        String
  ctaLink        String
  targetAudience String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("promo_banner")
}

model FlashSale {
  id          String   @id @default(cuid()) @map("_id")
  title       String
  description String?
  endsAt      DateTime
  isActive    Boolean  @default(true)
  productIds  String[] @db.ObjectId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("flash_sale")
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum Role {
  SUPER_ADMIN
  ADMIN
  CUSTOMER
}
